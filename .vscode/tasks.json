{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build SDL2 Snake Game",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",

                "main.cpp",
                "Game.cpp",
                "Snake.cpp",

                "-IC:/Coding Stuffs/Snakegamecpp/sdl2/include",
                "-LC:/Coding Stuffs/Snakegamecpp/sdl2/lib",

                "-lmingw32",
                "-lSDL2main",
                "-lSDL2",

                "-o",
                "C:/Coding Stuffs/Snakegamecpp/game.exe"
                
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}